# PhantomChat local dev env (gitignored). Copy to .env.local.
# This fork stubs the Telegram MTProto API on the main thread, so the
# API id/hash below are placeholders — fine for local P2P/nostr testing.
# For real Telegram connectivity, get your own from https://my.telegram.org
VITE_API_ID=1025907
VITE_API_HASH=452b0359b988148995f22ff0f4229750

# MTProto transport flags (stock telegram-web-k websocket setup)
VITE_MTPROTO_AUTO=
VITE_MTPROTO_HTTP=
VITE_MTPROTO_HTTP_UPLOAD=
VITE_MTPROTO_WORKER=1
VITE_MTPROTO_SW=
VITE_MTPROTO_HAS_HTTP=
VITE_MTPROTO_HAS_WS=1
VITE_SAFARI_PROXY_WEBSOCKET=

VITE_BUILD=1
