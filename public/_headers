/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

/sw-*.js
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/index.html
  Cache-Control: no-cache, must-revalidate

/
  Cache-Control: no-cache, must-revalidate

/update-manifest.json
  Cache-Control: no-cache, must-revalidate

# Canonical relay list — single source of truth shared with the phantombot
# server (which fetches this same URL over HTTP). Must revalidate so edits
# propagate to both the PWA and phantombot on next load instead of serving a
# CDN-stale copy.
/relays.json
  Cache-Control: no-cache, must-revalidate

/*.webmanifest
  Cache-Control: public, max-age=3600
